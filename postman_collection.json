{
  "info": {
    "name": "TP00001 School API",
    "description": "Multi-tenant school management API. Flow: principal -> create users (DOB password) -> classes/sections/subjects -> teaching assignments -> assignments -> submissions -> grading.\n\nUsage:\n1. Run **Auth > Login** (prefilled with the seeded principal) — it saves {{token}} automatically.\n2. The create requests save ids ({{classId}}, {{sectionId}}, {{subjectId}}, {{teacherId}}, {{studentId}}, {{teachingAssignmentId}}, {{assignmentId}}, {{submissionId}}) so later requests chain off them.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "teacherId", "value": "" },
    { "key": "studentId", "value": "" },
    { "key": "classId", "value": "" },
    { "key": "sectionId", "value": "" },
    { "key": "subjectId", "value": "" },
    { "key": "teachingAssignmentId", "value": "" },
    { "key": "assignmentId", "value": "" },
    { "key": "submissionId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Self Signup\",\n  \"email\": \"signup@greenwood.test\",\n  \"password\": \"Password@123\",\n  \"role\": \"teacher\",\n  \"schoolId\": \"PUT_SCHOOL_ID_HERE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login (saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('token', res.data.accessToken);",
                  "  console.log('token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal@greenwood.test\",\n  \"password\": \"Principal@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Logout All",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout-all",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout-all"]
            }
          }
        }
      ]
    },
    {
      "name": "Users (principal)",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
